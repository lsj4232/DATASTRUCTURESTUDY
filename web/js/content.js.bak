                { text: "if $p < r$",                               indent: 1 },
                { text: "q = ⌊(p + r) / 2⌋",                      indent: 2 },
                { text: "MERGE-SORT(A, p, q)",                    indent: 2 },
                { text: "MERGE-SORT(A, q + 1, r)",                indent: 2 },
