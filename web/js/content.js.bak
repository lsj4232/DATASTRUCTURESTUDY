                { text: "  ω_n^$n = 1$                                            ",    indent: 0 },
                { text: "  ω_n^{n/2} = -1  (Halving lemma 핵심)",                    indent: 0 },
                { text: "  ω_n^k · ω_n^{n/2} = ω_n^{k+n/2} = -ω_n^k",                 indent: 0 },
                { text: "",                                                           indent: 0 },
                { text: "Halving Lemma:",                                            indent: 0 },
