                { text: "A = ∅",                                      indent: 1 },
                { text: "while A does not form a spanning tree",      indent: 1 },
                { text: "find an edge (u, v) that is safe for A",     indent: 2 },
                { text: "$A = A$ ∪ {(u, v)}",                           indent: 2 },
                { text: "return A",                                   indent: 1 },
                { text: "",                                           indent: 0 },
