                { text: "      else $D[i,j] = 1$ + min(",                                  indent: 0 },
                { text: "            D[i-1, j],    // X[i] 삭제",                         indent: 0 },
                { text: "            D[i, j-1],    // Y[j] 삽입",                         indent: 0 },
                { text: "            D[i-1, j-1])  // 치환",                              indent: 0 },
                { text: "",                                                               indent: 0 },
                { text: "응용: 맞춤법 검사, DNA 정렬, diff 도구",                         indent: 0 },
