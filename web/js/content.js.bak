                  { text: "$f = o(g)$ — 더 작음", correct: false,
                    explain: "f/g → 2 (상수). 0이 아니므로 o 아님." },
                  { text: "$f = \omega (g)$ — 엄격히 큼", correct: false,
                    explain: "f/g → 2, ∞ 아니므로 ω 아님." },
                  { text: "비교 불가", correct: false,
                    explain: "비교 가능하고 명확히 Θ." },
