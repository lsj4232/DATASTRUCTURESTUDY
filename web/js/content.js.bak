      { q: "우선순위 큐의 HEAP-EXTRACT-MAX는 $O(\lg n)$이다.", a: true, why: "루트 제거 + MAX-HEAPIFY." },
      { q: "Heapsort의 최악 시간 복잡도는 $O(n \lg n)$이다.", a: true, why: "BUILD $O(n)$ + n번 EXTRACT $O(\lg n)$." },
    ],

