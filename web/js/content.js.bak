              { text: "// Step 1: 변수 가젯(variable gadget)",      indent: 1, note: "각 변수 x_i마다" },
              { text: "for each variable x_i",                      indent: 1, note: "" },
              { text: "add vertices {x_i, ¬x_i} with edge (x_i, ¬x_i)", indent: 2, note: "리터럴 쌍 + 간선" },
