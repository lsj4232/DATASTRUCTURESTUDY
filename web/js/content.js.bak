                { text: "  $k = 0$",                                            indent: 0 },
                { text: "  for $q = 2$ to m:",                                  indent: 0 },
                { text: "    while $k > 0$ and $P[k+1] \neq P[q]$:",                indent: 0 },
                { text: "      k = π[k]",                                     indent: 0 },
                { text: "    if P[k+1] == P[q]:",                            indent: 0 },
                { text: "      $k = k$ + 1",                                   indent: 0 },
                { text: "    π[q] = k",                                       indent: 0 },
                { text: "",                                                    indent: 0 },
                { text: "시간: Θ(m) — amortized 분석 (k는 최대 m번 증가)",    indent: 0 },
